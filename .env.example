# ===== IDM 环境变量模板 =====
# 复制: cp .env.example .env

# ===== Runtime =====
APP_ENV=local                    # local | dev | staging | prod
APP_NAME=idm
LOG_LEVEL=INFO
LOG_JSON=false

# ===== API =====
API_HOST=0.0.0.0
API_PORT=8080
API_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
API_WORKERS=1

# ===== Database (Postgres + AGE + pgvector) =====
# 本地 docker compose
DATABASE_URL=postgresql+asyncpg://idm:idm@localhost:5432/idm
# 同步 URL (Alembic 使用)
DATABASE_URL_SYNC=postgresql+psycopg://idm:idm@localhost:5432/idm
# 池
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ===== ClickHouse (GCE 生产 / docker 本地) =====
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=shop
CLICKHOUSE_USER=idm_ro
CLICKHOUSE_PASSWORD=idm_ro
CLICKHOUSE_SECURE=false
CLICKHOUSE_VERIFY=false

# ===== LLM (经 LiteLLM 网关, 详见 docs/design/llm-router.md) =====
# OpenAI (主力 gpt-5)
OPENAI_API_KEY=sk-replace-me
OPENAI_BASE_URL=https://api.openai.com/v1
# DeepSeek (备选)
DEEPSEEK_API_KEY=sk-replace-me
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# 本地 Qwen (兜底, Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:32b

# LLM 路由默认模型
IDM_LLM_PLANNER_MODEL=gpt-5
IDM_LLM_DEFAULT_MODEL=gpt-5
IDM_LLM_CHEAP_MODEL=deepseek-v3
IDM_LLM_LOCAL_MODEL=qwen2.5:32b
IDM_LLM_PII_MODEL=qwen2.5:32b   # PII 强制走本地

# ===== Langfuse (LLM 观测) =====
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_ENABLED=false

# ===== MCP =====
MCP_CLICKHOUSE_TRANSPORT=stdio
MCP_GITHUB_TRANSPORT=stdio
MCP_GITHUB_TOKEN=
MCP_GCS_TRANSPORT=stdio
MCP_SLACK_BOT_TOKEN=

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== GCS (大样本 / dbt manifest / Superset export) =====
GCS_BUCKET_IDM=idm-artifacts-local
GOOGLE_APPLICATION_CREDENTIALS=

# ===== Auth (M3+) =====
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=

# ===== Observability =====
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=idm-api
