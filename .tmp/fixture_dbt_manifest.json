      "description": "用户维度表, 整合来自 raw 层和 clickstream 的用户画像.",
      "raw_code": "{{ config(materialized='table') }}\n\nWITH first_orders AS (\n  SELECT user_id, MIN(created_at) AS first_order_at\n  FROM {{ ref('stg_orders') }}\n  WHERE status = 'paid'\n  GROUP BY user_id\n)\nSELECT\n  u.id          AS user_id,\n  u.email       AS email,\n  u.phone       AS phone,\n  cs.name_zh    AS country,\n  fo.first_order_at\nFROM {{ source('raw', 'users') }} u\nLEFT JOIN first_orders fo ON fo.user_id = u.id\nLEFT JOIN {{ ref('country_seed') }} cs ON cs.code = u.country_code\n",
      "columns": {
        "user_id": {"name": "user_id", "data_type": "Int64", "description": "用户主键"},
        "email": {"name": "email", "data_type": "String", "description": "用户邮箱, PII"},
        "phone": {"name": "phone", "data_type": "String", "description": "用户手机号, PII"},
        "country": {"name": "country", "data_type": "String", "description": "国家代码"},
        "first_order_at": {"name": "first_order_at", "data_type": "DateTime", "description": "首次下单时间"}
      },
      "depends_on": {"nodes": ["source.shop_dw.raw.users", "model.shop_dw.stg_orders", "model.shop_dw.country_seed"]}
    },
