# === Secret (明文 base64, 仅供本地 / 测试用) ===
# ⚠️  生产请使用 secrets-kms.yaml.example 走 KMS 加密
# 部署前: 把所有 REPLACE_ME 替换为实际值, 然后:
#   kubectl apply -f secrets.yaml

apiVersion: v1
kind: Secret
metadata:
  name: idm-api-env
  labels:
    app.kubernetes.io/name: idm
type: Opaque
stringData:
  DATABASE_URL: "postgresql+asyncpg://idm:idm@idm-pg:5432/idm"
  DATABASE_URL_SYNC: "postgresql+psycopg://idm:idm@idm-pg:5432/idm"
  CLICKHOUSE_HOST: "idm-clickhouse"
  CLICKHOUSE_PORT: "8123"
  CLICKHOUSE_USER: "idm_ro"
  CLICKHOUSE_PASSWORD: "idm_ro"
  OPENAI_API_KEY: "sk-replace-me"
  DEEPSEEK_API_KEY: "sk-replace-me"
  LANGFUSE_PUBLIC_KEY: ""
  LANGFUSE_SECRET_KEY: ""
  MCP_GITHUB_TOKEN: ""
  MCP_SLACK_BOT_TOKEN: ""
