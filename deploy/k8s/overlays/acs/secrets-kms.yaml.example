# === 阿里云 KMS 加密的 Secret (推荐, 替代明文 base64) ===
# 步骤:
#   1) 在阿里云 KMS 控制台创建密钥 idm-secret-key
#   2) 配置 KMS Encrypted Provider (见 https://help.aliyun.com/document_detail/139551.html)
#   3) kubectl apply -f secrets-kms.yaml
#
# 临时方案 (本地测试 / 起步): 用明文 base64 的 Secret, 见 secrets.yaml.example
# ⚠️  生产请一定用 KMS / External Secrets / 阿里云 Secrets Manager

apiVersion: v1
kind: Secret
metadata:
  name: idm-api-env
  labels:
    app.kubernetes.io/name: idm
  annotations:
    # 阿里云 KMS 加密: 部署前必须先配置 KMS Encrypted Provider
    # alibabacloud.com/kms-key-id: "key-xxxxxxxx"
    # alibabacloud.com/encryption-provider: "alibabacloud"
type: Opaque
stringData:
  # === Postgres 连接 (alicloud RDS / 自建 PG) ===
  # 占位: 部署前必须替换为实际值
  DATABASE_URL: "postgresql+asyncpg://idm:REPLACE_ME@idm-pg.idm.svc.cluster.local:5432/idm"
  DATABASE_URL_SYNC: "postgresql+psycopg://idm:REPLACE_ME@idm-pg.idm.svc.cluster.local:5432/idm"
  # === ClickHouse ===
  CLICKHOUSE_HOST: "idm-clickhouse"
  CLICKHOUSE_PORT: "8123"
  CLICKHOUSE_USER: "idm_ro"
  CLICKHOUSE_PASSWORD: "REPLACE_ME"
  # === LLM ===
  OPENAI_API_KEY: "REPLACE_ME"
  DEEPSEEK_API_KEY: "REPLACE_ME"
  # === Langfuse ===
  LANGFUSE_PUBLIC_KEY: ""
  LANGFUSE_SECRET_KEY: ""
  # === MCP Tokens ===
  MCP_GITHUB_TOKEN: ""
  MCP_SLACK_BOT_TOKEN: ""
